{
  "version": 2,
  "functions": {
    "api/index.js": {
      "runtime": "nodejs22.x"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/", "destination": "/zerogaspi/frontend/index.html" },
    { "source": "/(.*)", "destination": "/zerogaspi/frontend/$1" }
  ]
}
